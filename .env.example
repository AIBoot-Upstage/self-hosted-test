APP_ENV=local
PORT=8080

# Keep this unset for local demos, or set it and send Authorization: Bearer <value>.
AI_REVIEWER_TOKEN=change-me

# local: writes markdown comments under .local-data/comments
# github: posts a PR issue comment with GITHUB_TOKEN
PUBLISH_MODE=local
GITHUB_TOKEN=

# mock: deterministic local reviewer
# litellm: calls LiteLLM with the configured Solar3 models
LLM_MODE=mock
UPSTAGE_API_KEY=
SOLAR3_LOW_MODEL=solar3-low
SOLAR3_MEDIUM_MODEL=solar3-medium
SOLAR3_HIGH_MODEL=solar3-high

POLICY_ROOT=policies
LOCAL_DATA_DIR=.local-data
REVIEW_STORE_PATH=.local-data/reviews.json
COMMENT_OUTPUT_DIR=.local-data/comments

