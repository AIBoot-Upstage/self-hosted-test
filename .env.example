APP_ENV=local
PORT=8000

# 로컬 데모에서는 비워둘 수 있다. 값을 넣으면 Authorization: Bearer <value> 헤더가 필요하다.
AI_REVIEWER_TOKEN=change-me

# local: .local-data/comments 아래에 Markdown 댓글 파일을 저장한다.
# github: GITHUB_TOKEN으로 PR issue comment를 작성한다.
# github_app: webhook payload의 installation id로 GitHub App token을 발급해 댓글을 작성한다.
PUBLISH_MODE=local
GITHUB_TOKEN=

# GitHub App + webhook 연동 설정
# GitHub App webhook URL은 https://<host>/v1/github/webhooks 로 설정한다.
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_REVIEW_MODE=after_checks
GITHUB_APP_ID=
# 로컬 .env에는 한 줄 base64 PEM 사용을 권장한다. shell에서 직접 넘길 때는 원문 PEM도 사용할 수 있다.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_API_BASE_URL=https://api.github.com

# litellm: LiteLLM을 통해 Solar3를 호출하는 기본 실행 모드다.
# mock: 오프라인 개발용 deterministic reviewer를 사용한다.
LLM_MODE=litellm
UPSTAGE_API_KEY=
UPSTAGE_API_BASE_URL=https://api.upstage.ai/v1
SOLAR3_MODEL=solar-pro3
SOLAR3_LOW_REASONING_EFFORT=low
SOLAR3_MEDIUM_REASONING_EFFORT=medium
SOLAR3_HIGH_REASONING_EFFORT=high

# Langfuse Cloud (무료 티어). public/secret key를 채우면 모든 LiteLLM 호출이 자동으로
# 기록된다. 비워두면 Langfuse 연동은 비활성화된다.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

STORAGE_BACKEND=postgres
RAG_BACKEND=postgres
POSTGRES_DB=reviewer
POSTGRES_USER=reviewer
POSTGRES_PASSWORD=reviewer
DATABASE_URL=postgresql://reviewer:reviewer@postgres:5432/reviewer

POLICY_ROOT=policies
LOCAL_DATA_DIR=.local-data
REVIEW_STORE_PATH=.local-data/reviews.json
COMMENT_OUTPUT_DIR=.local-data/comments
